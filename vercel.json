{
  "buildCommand": "npm install --prefix frontend && CI=false npm run build --prefix frontend",
  "outputDirectory": "frontend/build",
  "env": {
    "SKIP_PREFLIGHT_CHECK": "true",
    "DISABLE_ESLINT_PLUGIN": "true"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
